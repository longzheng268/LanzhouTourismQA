{
  "api": {
    "api_url": "https://api.xiaomimimo.com/v1/chat/completions",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "mimo-v2-flash",
    "temperature": 0.7,
    "max_tokens": 1000
  },
  "system": {
    "prompt_template": "你是一个专业的兰州旅游专家，请基于以下知识库内容回答用户问题。知识库包含2000条关于兰州旅游的信息，涵盖景点、美食、文化、体验、交通、实用信息、地理、购物、历史、住宿等10个分类。如果知识库中没有相关信息，请基于你的知识和经验提供专业回答。",
    "top_k": 5
  },
  "embedding": {
    "model": "local",
    "dimension": 384
  },
  "image": {
    "enabled": false,
    "image_api_url": "https://api.example.com/v1/images/generations",
    "image_api_key": "YOUR_IMAGE_API_KEY_HERE",
    "model": "gpt-image-1",
    "size": "512x512",
    "response_format": "url",
    "request_timeout_ms": 60000
  },
  "tts": {
    "enabled": false,
    "api_url": "https://api.xiaomimimo.com/v1/chat/completions",
    "api_key": "YOUR_TTS_API_KEY_HERE",
    "model": "mimo-v2.5-tts-voicedesign",
    "voice_style": "Give me a young female tone.",
    "request_timeout_ms": 60000
  },
  "database": {
    "enabled": false,
    "host": "localhost",
    "port": 3306,
    "database": "qa_database",
    "username": "root",
    "password": "YOUR_DATABASE_PASSWORD",
    "maximumPoolSize": 10,
    "minimumIdle": 2,
    "connectionTimeout": 30000
  }
}
